{
	"schemaVersion": 1,
	"id": "bettercamels",
	"version": "${version}",
	"name": "Better Camels",
	"description": "Mojang added the coolest mob ever and made it a two seater horse that can dash instead of jump. This mod adds the functionality that the camel should have had from day one",
	"authors": [
		"Nocere",
		"Astra"
	],
	"contact": {
		"sources": "https://github.com/nocere-dev/Minecraft-Better-Camels-Mod",
		"issues": "https://github.com/nocere-dev/Minecraft-Better-Camels-Mod/issues"
	},
	"license": "Custom",
	"icon": "assets/bettercamels/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.nocere.bettercamels.BetterCamels"
		],
		"fabric-datagen": [
			"com.nocere.bettercamels.BetterCamelsDataGenerator"
		],
		"client": [
			"com.nocere.bettercamels.BetterCamelsClient"
		]
	},
	"mixins": [
		"bettercamels.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}