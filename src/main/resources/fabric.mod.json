	"authors": [
		"Nocere",
		"Astra"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "Custom",
	"icon": "assets/better-camels/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.nocere.bettercamels.BetterCamels"
		],
		"fabric-datagen": [
			"com.nocere.bettercamels.BetterCamelsDataGenerator"
		],
		"client": [
			"com.nocere.BetterCamels.BetterCamelsClient"
		]
	},
	"mixins": [
		"better-camels.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
